<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Search text input bar -->
    <LinearLayout
        android:id="@+id/emoji_search_input_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="?attr/keyboardViewBackground">

        <EditText
            android:id="@+id/emoji_search_field"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:focusable="false"
            android:inputType="none"
            android:hint="Search emoji…"
            android:singleLine="true"
            android:textSize="15sp"
            android:textColor="?attr/functionalTextColor"
            android:textColorHint="?attr/functionalTextColor"
            android:background="?attr/keyboardViewBackground"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center_vertical" />

        <Button
            android:id="@+id/emoji_search_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="✕"
            android:textSize="15sp"
            android:textColor="?attr/functionalTextColor"
            android:background="?android:attr/selectableItemBackground"
            android:padding="0dp"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- Emoji results strip + delete button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="?attr/keyboardViewBackground">

        <uk.coko.forge.kokey.emoji.EmojiSearchStripView
            android:id="@+id/emoji_search_strip"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/emoji_search_delete"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:text="⌫"
            android:textSize="15sp"
            android:textColor="?attr/functionalTextColor"
            android:background="?android:attr/selectableItemBackground"
            android:padding="0dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp" />

    </LinearLayout>

</merge>
